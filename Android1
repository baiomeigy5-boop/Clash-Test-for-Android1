mixed-port: 7890
allow-lan: false
mode: global
log-level: info

tun:
  enable: true
  stack: gvisor
  auto-route: true
  auto-detect-interface: true

proxy-providers:
  mysub:
    type: http
    url: "https://a02.fflink.cc/api/v1/client/subscribe?token=a82921fe732a4256b89ad837b444565e"
    interval: 3600
    path: ./mysub.yaml
    health-check:
      enable: true
      interval: 300
      url: "http://www.gstatic.com/generate_204"

proxies:
  - name: SK5
    type: socks5
    server: 220.132.60.157
    port: 31670
    username: lan
    password: "123"

proxy-groups:
  - name: TW-Nodes
    type: url-test
    proxies:
      - mysub
    filter: "(?i)tw|taiwan"
    url: "http://www.gstatic.com/generate_204"
    interval: 300

  - name: Relay
    type: relay
    proxies:
      - TW-Nodes
      - SK5

  - name: Proxy
    type: select
    proxies:
      - Relay
      - TW-Nodes
      - DIRECT

rules:
  - MATCH,Proxy
