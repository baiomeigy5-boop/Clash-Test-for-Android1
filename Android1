port: 7890
socks-port: 7891
mixed-port: 7893
allow-lan: true
mode: rule
log-level: info
ipv6: false
udp: true # 強制開啟 UDP

# 1. 訂閱連結管理 (自動抓取您的節點)
proxy-providers:
  fflink-sub:
    type: http
    url: "https://a02.fflink.cc/api/v1/client/subscribe?token=35f52f25e464a21c35a77b199ea831c5"
    interval: 3600
    path: ./fflink.yaml
    health-check:
      enable: true
      interval: 600
      url: http://www.gstatic.com/generate_204

proxies:
  # 2. 您的 SK5 落地節點 (手動填寫)
  - name: "SK5_落地出口"
    type: socks5
    server: 220.132.60.157
    port: 31670
    username: "lan"
    password: "123"
    udp: true

proxy-groups:
  # 代理鏈邏輯：自動從訂閱找「台湾 TW-01」 -> 串接 SK5
  - name: "UDP轉發鏈路"
    type: relay
    proxies:
      - "中轉入口"
      - "SK5_落地出口"

  # 利用篩選功能，只抓取名稱包含 "台湾 TW-01" 的節點
  - name: "中轉入口"
    type: select
    use:
      - fflink-sub
    filter: "台湾 TW-01"

rules:
  - MATCH, UDP轉發鏈路
