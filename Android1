mixed-port: 7890
allow-lan: false
mode: global
log-level: info

tun:
  enable: true
  stack: gvisor
  auto-route: true
  auto-detect-interface: true

proxies:
  # SK5
  - name: SK5
    type: socks5
    server: 220.132.60.157
    port: 31670
    username: "lan"
    password: "123"

  # 訂閱節點（你可以用 provider 自動更新生成的節點）
  # 這裡示範幾個台灣節點名稱作為例子
  - name: TW-Node1
    type: vmess
    server: example.tw1.com
    port: 443
    uuid: 你的UUID
    alterId: 0
    cipher: auto
    tls: true

  - name: TW-Node2
    type: vmess
    server: example.tw2.com
    port: 443
    uuid: 你的UUID
    alterId: 0
    cipher: auto
    tls: true

proxy-groups:
  - name: TW-Nodes
    type: url-test
    proxies:
      - TW-Node1
      - TW-Node2
    url: "http://www.gstatic.com/generate_204"
    interval: 300

  - name: Relay
    type: relay
    proxies:
      - TW-Nodes
      - SK5

  - name: Proxy
    type: select
    proxies:
      - Relay
      - TW-Nodes
      - DIRECT

rules:
  - MATCH,Proxy
