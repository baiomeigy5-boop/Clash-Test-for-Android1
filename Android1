port: 7890
socks-port: 7891
mixed-port: 7893
allow-lan: true
mode: rule
log-level: info
ipv6: false
udp: true

dns:
  enable: true
  enhanced-mode: fake-ip
  nameserver:
    - 114.114.114.114
    - 8.8.8.8

proxies:
  # 1. 台灣 Trojan 節點 (手動填入)
  # 請打開您的訂閱內容，把「台湾 TW-01」的伺服器位址和密碼填進去
  - name: "台湾 TW-01"
    type: trojan
    server: 這裡填入伺服器位址(例如 tw01.fflink.cc)
    port: 443
    password: 這裡填入密碼
    udp: true
    sni: 這裡填入SNI(通常跟server一樣)
    skip-cert-verify: true

  # 2. 您的 SK5 落地節點
  - name: "SK5_落地出口"
    type: socks5
    server: 220.132.60.157
    port: 31670
    username: "lan"
    password: "123"
    udp: true

proxy-groups:
  # 代理鏈邏輯
  - name: "UDP轉發鏈路"
    type: relay
    proxies:
      - "台湾 TW-01"
      - "SK5_落地出口"

rules:
  - MATCH, UDP轉發鏈路
