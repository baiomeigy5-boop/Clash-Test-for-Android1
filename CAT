# Generated for Clash Verge - 2026-04-13 手動優化版
mode: rule
mixed-port: 7897
socks-port: 7898
port: 7899
allow-lan: true
log-level: info
external-controller: 127.0.0.1:9097

tun:
  enable: true
  stack: system
  device: Meta
  auto-route: true
  strict-route: true
  auto-detect-interface: true
  dns-hijack:
    - any:53
  mtu: 1500

dns:
  enable: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  nameserver:
    - 1.1.1.1
    - 8.8.8.8
  fake-ip-filter:
    - dns.msftncsi.com
    - www.msftncsi.com
    - www.msftconnecttest.com

proxy-providers:
  shanhuyun:
    type: http
    url: "https://resourcemap.lol/sub?token=ca1B7tcnwvX6oUdY0ylgvfkMOyOXhRgcOZdFrVeNGdo&type=clash&protocol=ss2022&use=domestic&rule=default"
    interval: 3600
    path: ./providers/shanhuyun.yaml
    health-check:
      enable: true
      url: "https://www.gstatic.com/generate_204"
      interval: 300

proxy-groups:
  - name: 🇸🇬 新加坡
    type: url-test
    use: [shanhuyun]
    filter: "Singapore 0[1-5]"
    url: "https://www.gstatic.com/generate_204"
    interval: 300
    tolerance: 50

  - name: 🇯🇵 日本
    type: url-test
    use: [shanhuyun]
    filter: "Japan 0[1-5]"
    url: "https://www.gstatic.com/generate_204"
    interval: 300
    tolerance: 50

  - name: 🚀 Proxy
    type: select
    proxies:
      - 🇸🇬 新加坡
      - 🇯🇵 日本
      - DIRECT

rules:
  - GEOIP,CN,DIRECT
  - MATCH,🚀 Proxy
