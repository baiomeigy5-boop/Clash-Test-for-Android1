# Generated by Clash Verge - 本地配置修正版

mode: global
mixed-port: 7897
socks-port: 7898
port: 7899
allow-lan: false
log-level: info
secret: ''
external-controller: 127.0.0.1:9097

tun:
  stack: system
  device: Meta
  auto-route: true
  strict-route: true
  auto-detect-interface: true
  dns-hijack:
  - any:53
  mtu: 1500
  enable: true

dns:
  enable: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  nameserver:
  - 1.1.1.1
  - 8.8.8.8
  fallback: []
  fake-ip-filter:
  - dns.msftncsi.com
  - www.msftncsi.com
  - www.msftconnecttest.com

# 這裡改用直接訂閱模式，不透過 proxy-providers 外部檔案
proxies: []

proxy-providers:
  my_sub:
    type: http
    # 這裡加入轉化參數，確保回傳的是標準 YAML
    url: "https://scdy03.scsub.com/apiv2/7ckvsf9lws3zxztu?clash=1&extend=1"
    interval: 0
    path: ./providers/my_sub.yaml
    health-check:
      enable: true
      url: "https://www.gstatic.com/generate_204"
      interval: 300

proxy-groups:
# 🇸🇬 新加坡 - 精確篩選 01 到 10
- name: 🇸🇬 新加坡
  type: fallback
  use:
  - my_sub
  filter: "新加坡-(0[1-9]|10)"
  url: "https://www.gstatic.com/generate_204"
  interval: 15

# 🇯🇵 日本 - 精確篩選 01 到 10
- name: 🇯🇵 日本
  type: fallback
  use:
  - my_sub
  filter: "日本-(0[1-9]|10)"
  url: "https://www.gstatic.com/generate_204"
  interval: 15

# 🚀 出口
- name: 🚀 Proxy
  type: select
  proxies:
  - 🇸🇬 新加坡
  - 🇯🇵 日本
  - DIRECT

rules:
- MATCH,🚀 Proxy
