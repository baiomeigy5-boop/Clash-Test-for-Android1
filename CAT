# Generated for Clash Verge - 電腦版修正版
mode: rule
mixed-port: 7897
socks-port: 7898
port: 7899
allow-lan: true
log-level: info
external-controller: 127.0.0.1:9097

tun:
  enable: true
  stack: system
  device: Meta
  auto-route: true
  strict-route: true
  auto-detect-interface: true
  dns-hijack:
    - any:53
  mtu: 1500

dns:
  enable: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  nameserver:
    - 1.1.1.1
    - 8.8.8.8
  fake-ip-filter:
    - dns.msftncsi.com
    - www.msftncsi.com
    - www.msftconnecttest.com

proxy-providers:
  shanhuyun:
    type: http
    # 已更新為您最新的連結
    url: "https://scdy03.scsub.com/apiv2/evwhndbve8y6cdxx?clash=1&extend=1"
    interval: 0
    path: ./providers/airport.yaml
    # 移除容易報錯的 header 區塊，確保兼容性
    filter: "(?i)新加坡|日本"
    health-check:
      enable: true
      url: "https://www.gstatic.com/generate_204"
      interval: 300

proxy-groups:
# 🇸🇬 新加坡 - 篩選 01 到 10
- name: 🇸🇬 新加坡
  type: fallback
  use: [shanhuyun]
  filter: "新加坡-(0[1-9]|10)$"
  url: "https://www.gstatic.com/generate_204"
  interval: 15

# 🇯🇵 日本 - 篩選 01 到 10
- name: 🇯🇵 日本
  type: fallback
  use: [shanhuyun]
  filter: "日本-(0[1-9]|10)$"
  url: "https://www.gstatic.com/generate_204"
  interval: 15

# 🚀 出口選擇
- name: 🚀 Proxy
  type: select
  proxies:
  - 🇸🇬 新加坡
  - 🇯🇵 日本
  - DIRECT

rules:
- MATCH,🚀 Proxy
