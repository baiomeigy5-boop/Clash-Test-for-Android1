mode: rule  # 1. 改為 rule 模式，畫面會比較乾淨
mixed-port: 7897
# ... 前面設定保持不變 ...

proxy-providers:
  shanhuyun:
    type: http
    url: "https://scdy03.scsub.com/apiv2/7ckvsf9lws3zxztu?clash=1&extend=1"
    interval: 0
    path: ./providers/airport.yaml
    header:
      User-Agent: "ClashMeta"
    # 2. 在源頭就先過濾，只抓取「新加坡」或「日本」開頭的節點
    filter: "(?i)新加坡|日本" 
    health-check:
      enable: true
      url: "https://www.gstatic.com/generate_204"
      interval: 300

proxy-groups:
- name: 🇸🇬 新加坡
  type: fallback
  use: [shanhuyun]
  # 這裡保留精確篩選 01-10
  filter: "新加坡-(0[1-9]|10)$"
  url: "https://www.gstatic.com/generate_204"
  interval: 15

- name: 🇯🇵 日本
  type: fallback
  use: [shanhuyun]
  # 這裡保留精確篩選 01-10
  filter: "日本-(0[1-9]|10)$"
  url: "https://www.gstatic.com/generate_204"
  interval: 15

- name: 🚀 Proxy
  type: select
  proxies:
  - 🇸🇬 新加坡
  - 🇯🇵 日本
  - DIRECT

rules:
- MATCH,🚀 Proxy
