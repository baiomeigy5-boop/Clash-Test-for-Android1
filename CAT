# Generated for Clash Verge - 2026-04-11 更新版(V2 GY6)
mode: rule
mixed-port: 7897
socks-port: 7898
port: 7899
allow-lan: true
log-level: info
external-controller: 127.0.0.1:9097

tun:
  enable: true
  stack: system
  device: Meta
  auto-route: true
  strict-route: true
  auto-detect-interface: true
  dns-hijack:
    - any:53
  mtu: 1500

dns:
  enable: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  nameserver:
    - 1.1.1.1
    - 8.8.8.8
  fake-ip-filter:
    - dns.msftncsi.com
    - www.msftncsi.com
    - www.msftconnecttest.com

proxy-providers:
  shanhuyun:
    type: http
    # 已更新為您最新的訂閱連結
    url: "https://resourcemap.lol/sub?token=ufxu1TWXl81teDy-acfELFE1LMAEAp0QbiFXbDw--Lw&type=clash&protocol=ss2022&use=foreign&rule=default"
    # 設定為 0，禁用定時自動更新
    interval: 0
    path: ./providers/shanhuyun.yaml
    health-check:
      enable: true
      url: "https://www.gstatic.com/generate_204"
      interval: 300

proxy-groups:
# 🇸🇬 新加坡 - 篩選 Singapore 01 到 05
- name: 🇸🇬 新加坡
  type: fallback
  use: [shanhuyun]
  filter: "Singapore 0[1-5]"
  url: "https://www.gstatic.com/generate_204"
  interval: 15

# 🇯🇵 日本 - 篩選 Japan 01 到 05
- name: 🇯🇵 日本
  type: fallback
  use: [shanhuyun]
  filter: "Japan 0[1-5]"
  url: "
